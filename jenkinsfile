pipeline {
    agent any

    environment {
        IMAGE_NAME = "selvatharun2812/pizza-app"
        CONTAINER_NAME = "pizza-container"
        PORT = "5000"
        PYTHON_PATH = "C:\\Users\\Selva Tharun R R\\AppData\\Local\\Python\\bin\\python.exe"
    }

    stages {

        stage('Install Dependencies') {
            steps {
                bat '"%PYTHON_PATH%" -m pip install -r requirements.txt'
            }
        }

        stage('Run Tests') {
            steps {
                bat '"%PYTHON_PATH%" -m pytest || exit 0'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def tag = "${BUILD_NUMBER}"
                    appImage = docker.build("${IMAGE_NAME}:${tag}")
                }
            }
        }

        // stage('Security Scan') {
        //     steps {
        //         bat 'trivy image %IMAGE_NAME%:latest'
        //     }
        // }

        stage('Push to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('', 'docker-hub-creds') {
                        appImage.push("${BUILD_NUMBER}")
                        appImage.push("latest")
                    }
                }
            }
        }

        stage('Pull Latest Image') {
            steps {
                bat 'docker pull %IMAGE_NAME%:latest'
            }
        }

        stage('Stop Old Container') {
            steps {
                bat 'docker rm -f %CONTAINER_NAME% || exit 0'
            }
        }

        stage('Run New Container') {
            steps {
                bat 'docker run -d -p %PORT%:%PORT% --name %CONTAINER_NAME% %IMAGE_NAME%:latest'
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed'
        }
        success {
            echo 'Deployment successful'
        }
        failure {
            echo 'Pipeline failed'
        }
    }
}