pipeline {
    agent any

    environment {
        IMAGE_NAME = "selvatharun2812/pizza-app"
        PORT = "5000"
        PYTHON_PATH = "C:\\Users\\Selva Tharun R R\\AppData\\Local\\Python\\bin\\python.exe"
    }

    stages {

        stage('Install Dependencies') {
            steps {
                bat '"%PYTHON_PATH%" -m pip install -r requirements.txt'
            }
        }

        stage('Run Tests') {
            steps {
                bat '"%PYTHON_PATH%" -m pytest tests/ --junitxml=test-results.xml || exit 0'
            }
            post {
                always {
                    junit 'test-results.xml'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def tag = "${BUILD_NUMBER}"
                    appImage = docker.build("${IMAGE_NAME}:${tag}")
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('', 'docker-hub-creds') {
                        appImage.push("${BUILD_NUMBER}")
                        appImage.push("latest")
                    }
                }
            }
        }

        stage('Deploy with Docker Compose') {
            steps {
                // Force remove any orphan container not tracked by compose
                bat 'docker rm -f pizza-container || exit 0'
                bat 'docker compose down --remove-orphans'
                bat 'docker compose pull'
                bat 'docker compose up -d --build'
            }
        }

        stage('Health Check') {
            steps {
                bat 'docker compose ps'
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed'
        }
        success {
            echo 'Deployment successful - app running on port 5000'
        }
        failure {
            bat 'docker compose logs --tail=50'
            echo 'Pipeline failed - check logs above'
        }
    }
}
